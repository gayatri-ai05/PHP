Q12.Write a PHP script to generate an XML file in the following format using SimpleXML functions.
<?xml version="1.0" encoding="UTF-8"?>
<BookInfo>
<book>
<bookno>1</bookno>
<bookname>JAVA</bookname>
<authorname> Balguru Swami</authorname>
<price>250</price>
<year>2006</year>
</book>
<book>
<bookno>2</bookno>
<BookInfo>
<book>
<bookname>C</bookname>
<authorname>Denis Ritchie</authorname>
<price>500</price>
<year>1971</year>
</book>
</BookInfo>

Answer:::::::::::::::::::::::::::::::::::::::::::::

<?php
$xml=new SimpleXMLElement("<BookInfo></BookInfo>");

$book1 = $xml->addChild("book");
$book1->addChild("bookno","1");
$book1->addChild("bookname","JAVA");
$book1->addChild("authorname","Balguru Swami");
$book1->addChild("price","250");
$book1->addChild("year","2006");

$book2 = $xml->addChild("book");
$book2->addChild("bookno","2");
$book2->addChild("bookname","C");
$book2->addChild("authorname","Denis Ritchie");
$book2->addChild("price","500");
$book2->addChild("year","1971");

$xml->asXML("books1.xml");

echo "XML File Created";
?>

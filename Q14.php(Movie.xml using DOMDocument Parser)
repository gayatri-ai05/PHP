2nd code save with .php:::::::::::::::::::::::::::::
<?php
$dom=new DomDocument();
$dom->load("Q14_1.xml");
$title=$dom->getElementsByTagName("mtitle");
$actor=$dom->getElementsByTagName("aname");
foreach($title as $m)
{
	echo "<br>Movie Title : ".$m->textContent;
}
foreach($actor as $a)
{
	echo "<br>Actor Name : ".$a->textContent;
}
?>

<?php
session_start();

if(!isset($_SESSION['attempt']))
{
    $_SESSION['attempt']=0;
}

if(isset($_POST['uname']) && isset($_POST['pass']))
{
    $u=$_POST['uname'];
    $p=$_POST['pass'];

    if($_SESSION['attempt']<3)
    {
        if($u=="admin" && $p=="bcs123")
        {
            echo "Welcome";

            // Second form
            echo "<form>";
            echo "<br>Second Form<br>";
            echo "<input type='text' placeholder='Enter something'>";
            echo "</form>";
        }
        else
        {
            echo "error occured";
            $_SESSION['attempt']+=1;
        }
    }
    else
    {
        echo "reach maximum attempt";
    }
}
?>


Q18.Write a javascript function to validate username and password for a membership form. 

Answer:::::::::::::::::::::::::::::::::::
<html>
<head>
<script>
	function validate()
	{
		var name=document.getElementById("t1").value;
		var pass=document.getElementById("t2").value;
		
		var namered = /^[A-Z]+[0-9]+$/;
		var passred = /^[a-z]+[0-9]+$/;
		
		if(name.match(namered)&& pass.match(passred))
		{
			window.alert("Login successfully");
			return true;
		}
		else
		{
			window.alert("Invalid");
			return false;
		}
	}
</script>
</head>

<body>
<form onsubmit="return validate()">
Enter Username: <input type="text" id="t1"><br>
Enter Password: <input type="password" id="t2"><br>
<input type="Submit" value="submit">
</form>
</body>
</html>
